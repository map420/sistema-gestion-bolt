# ─────────────────────────────────────────────────────────────────────────────
# .env.example — SaaS Factory
# Copia a .env.local y rellena con valores reales.
# NUNCA commitear este archivo con valores reales.
# Para obtener cada credencial: knowledge/integraciones-credenciales.md
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NombreProducto

# ── Supabase (obligatorio) ────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...          # formato JWT, no sb_publishable_
SUPABASE_SERVICE_ROLE_KEY=eyJ...              # formato JWT, no sb_secret_

# ── Database (obligatorio) ────────────────────────────────────────────────────
# DATABASE_URL  → Transaction Pooler (puerto 6543) — para queries en runtime
# DIRECT_URL    → Conexión directa (puerto 5432) — para prisma migrate
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.<ref>:<password>@db.<ref>.supabase.co:5432/postgres
# ⚠️ Contraseña sin caracteres especiales (!, @, #) — causan errores de URL encoding

# ── Billing ───────────────────────────────────────────────────────────────────
# mock = sin Stripe, stripe = Stripe real
BILLING_MODE=mock

STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs (uno por plan)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# ── Email — Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── WhatsApp — Meta Cloud API (opcional) ─────────────────────────────────────
# Dejar vacío para operar en modo mock (mensajes se loguean, no se envían)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=     # string aleatorio, mín. 16 chars

# ── Cron jobs ─────────────────────────────────────────────────────────────────
CRON_SECRET=                       # string aleatorio — protege endpoints de cron

# ── IA — OpenAI (si el producto usa IA) ──────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── IA — Anthropic / Claude (si el producto usa IA) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Analytics — PostHog ───────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Monitoreo — Sentry ────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
